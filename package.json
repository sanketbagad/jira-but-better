{
  "name": "todoapp-server",
  "version": "1.0.0",
  "description": "Backend for ToDoApp (Jira-but-better) - Node.js, PostgreSQL, Upstash Redis, QStash",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "migrate:down": "node src/db/migrate.js down"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "@upstash/qstash": "^2.7.17",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.13.0",
    "resend": "^6.9.4",
    "uuid": "^10.0.0"
  }
}
